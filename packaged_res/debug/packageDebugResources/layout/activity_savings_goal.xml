<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_teal"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Savings Goals"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save for your dreams"
            android:textSize="12sp"
            android:textColor="#ffffff99"/>

    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Add Goal Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add New Savings Goal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:paddingBottom="12dp"/>

                <EditText
                    android:id="@+id/goalNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Goal Name (e.g. New Laptop)"
                    android:inputType="text"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/targetAmountInput"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Target Amount (R)"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/savedAmountInput"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Already Saved (R) - optional"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_dark"
                    android:textColorHint="@color/text_hint"
                    android:background="@drawable/input_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/saveSavingsGoalBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Save Goal"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:background="@drawable/button_primary"/>

            </LinearLayout>

            <!-- Goals List -->
            <LinearLayout
                android:id="@+id/goalsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
