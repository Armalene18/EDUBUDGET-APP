<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/edubudget_logo_img"
        android:roundIcon="@drawable/edubudget_logo"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EduBudget">

        <!-- LOGIN (START SCREEN) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- MAIN SCREENS -->
        <activity android:name=".DashboardActivity" android:exported="false" />
        <activity android:name=".ExpenseActivity" android:exported="false" />
        <activity android:name=".ExpenseListActivity" android:exported="false" />
        <activity android:name=".CategoryActivity" android:exported="false" />
        <activity android:name=".BudgetGoalActivity" android:exported="false" />
        <activity android:name=".CreateProfileActivity" android:exported="false" />

        <!-- NEW FINAL POE SCREENS -->
        <activity android:name=".SpendingGraphActivity" android:exported="false" />
        <activity android:name=".BadgesActivity" android:exported="false" />
        <activity android:name=".SavingsGoalActivity" android:exported="false" />
        <activity android:name=".NoSpendDayActivity" android:exported="false" />

        <!-- BASE / SUPPORT -->
        <activity android:name=".BaseActivity" android:exported="false" />
        <activity android:name=".item_expense" android:exported="false" />

        <!-- Notification Receiver -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false"/>

    </application>

</manifest>
